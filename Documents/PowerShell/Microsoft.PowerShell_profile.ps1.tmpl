# Oh My Posh prompt
if (Get-Command oh-my-posh -ErrorAction SilentlyContinue) {
    oh-my-posh init pwsh --config "$HOME/.config/omp/omp.toml" | Invoke-Expression
}

# mise runtime manager
if (Get-Command mise -ErrorAction SilentlyContinue) {
    mise activate pwsh | Invoke-Expression
}

# zoxide (better cd)
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
    Invoke-Expression (& { (zoxide init powershell | Out-String) })
}

# Aliases
function l  { eza --icons -a --group-directories-first @args }
function ll { eza --icons -la --group-directories-first @args }
function la { eza --icons -la --group-directories-first @args }
function lt { eza --icons --tree --group-directories-first @args }

Set-Alias -Name vim  -Value nvim -Option AllScope
Set-Alias -Name vi   -Value nvim -Option AllScope
Set-Alias -Name g    -Value git  -Option AllScope
Set-Alias -Name lg   -Value lazygit -Option AllScope

function cat { bat @args }
function cz  { chezmoi @args }

# Git shortcuts
function gs   { git status @args }
function ga   { git add @args }
function gc   { git commit @args }
function gp   { git push @args }
function gl   { git pull @args }
function glog { git log --oneline --graph --decorate @args }

# Navigation
function ..   { Set-Location .. }
function ...  { Set-Location ../.. }

# Neovim as editor
$env:EDITOR = "nvim"
