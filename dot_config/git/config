[user]
	email = evan@wool.homes
	name = esize
	signingkey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = main
[core]
	editor = nvim
  pager = delta

[delta]
  lineNumbers = true

[push]
  autoSetupRemote = true
  default = current

[alias]
  undo = reset --soft HEAD^
[gpg]
	format = ssh
[commit]
	gpgsign = true
[credential "https://github.com"]
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = !gh auth git-credential
